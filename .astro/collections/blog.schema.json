{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "type": {
      "default": "article",
      "type": "string",
      "enum": [
        "article",
        "note",
        "links",
        "video",
        "question"
      ]
    },
    "date": {
      "type": "string",
      "format": "date-time"
    },
    "description": {
      "type": "string"
    },
    "quote": {
      "type": "string"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "title",
          "url"
        ]
      }
    },
    "video": {
      "type": "string"
    },
    "draft": {
      "default": false,
      "type": "boolean"
    },
    "$schema": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}