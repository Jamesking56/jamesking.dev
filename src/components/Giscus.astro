---
interface Props {
  repo: string;
  repoId: string;
  category: string;
  categoryId: string;
}

const { repo, repoId, category, categoryId } = Astro.props;
---

<div class="mt-12 pt-8 border-t border-tokyo-border">
  <h2 class="text-xl font-semibold text-tokyo-fg-bright mb-6">Comments</h2>
  <script 
    src="https://giscus.app/client.js"
    data-repo={repo}
    data-repo-id={repoId}
    data-category={category}
    data-category-id={categoryId}
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-theme="dark_dimmed"
    data-lang="en"
    data-loading="lazy"
    crossorigin="anonymous"
    async
  ></script>
</div>