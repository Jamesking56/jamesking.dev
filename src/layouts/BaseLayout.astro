---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
}

const {
  title,
  description = "AI-Augmented Software Engineer | Laravel, PHP, Kubernetes Expert",
  image = "/og-image.svg",
  type = "website",
  publishedTime,
  author = "James King"
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en-gb" style="color-scheme: dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#1a1b26" />
    <ClientRouter fallback="swap" />
    
    <!-- Primary Meta Tags -->
    <title>{title}{type === 'article' && Astro.url.pathname.startsWith('/blog') ? ' | Blog' : ''} | James King</title>
    <meta name="title" content={`${title}${type === 'article' && Astro.url.pathname.startsWith('/blog') ? ' | Blog' : ''} | James King`} />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    
    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={type === 'article' && Astro.url.pathname.startsWith('/blog') ? `${title} | Blog` : title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="James King" />
    <meta property="og:locale" content="en_GB" />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {author && <meta property="article:author" content={author} />}
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={type === 'article' && Astro.url.pathname.startsWith('/blog') ? `${title} | Blog` : title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, Astro.site)} />
    <meta name="twitter:creator" content="@jamesking56" />
    <meta name="twitter:site" content="@jamesking56" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.bunny.net/css?family=jetbrains-mono:400,500,600,700" rel="stylesheet" />
    
    <!-- Counter.dev Analytics - only on production -->
    {Astro.url.hostname === 'jamesking.dev' && (
      <script type="text/partytown" src="https://cdn.counter.dev/script.js" data-id="c81d2e80-c20e-41d0-87f3-39a53030f73a" data-utcoffset="1"></script>
    )}

    <!-- GhostlyX Analytics - only on production -->
    {Astro.url.hostname === 'jamesking.dev' && (
      <script defer data-domain="jamesking.dev" data-site-id="gx_dtLjGLHWPhaO" src="https://ghostlyx.com/js/script.js"></script>
    )}
    
    <!-- JSON-LD Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": type === 'article' ? 'BlogPosting' : 'WebSite',
      "name": title,
      "description": description,
      "url": canonicalURL,
      ...(type === 'article' ? {
        "headline": title,
        "author": {
          "@type": "Person",
          "name": author,
          "url": "https://jamesking.dev"
        },
        "datePublished": publishedTime,
        "image": "https://jamesking.dev/og-image.png"
      } : {
        "potentialAction": {
          "@type": "SearchAction",
          "target": {
            "@type": "EntryPoint",
            "urlTemplate": "https://jamesking.dev/blog?q={search_term_string}"
          },
          "query-input": "required name=search_term_string"
        }
      }),
      "publisher": {
        "@type": "Person",
        "name": "James King",
        "jobTitle": "AI-Augmented Software Engineer",
        "url": "https://jamesking.dev"
      }
    })} />
    
    <!-- Organization Schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "James King",
      "url": "https://jamesking.dev",
      "sameAs": [
        "https://github.com/Jamesking56",
        "https://linkedin.com/in/jamesking56"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "james@jamesking.dev",
        "contactType": "Developer"
      }
    })} />
    
    <!-- Person Schema (always loaded) -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "James King",
      "jobTitle": "AI-Augmented Software Engineer",
      "url": "https://jamesking.dev",
      "email": "james@jamesking.dev",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Redditch",
        "addressCountry": "UK"
      },
      "sameAs": [
        "https://github.com/Jamesking56",
        "https://linkedin.com/in/jamesking56"
      ],
      "knowsAbout": [
        "Laravel",
        "PHP",
        "Symfony",
        "JavaScript",
        "React",
        "Kubernetes",
        "Docker",
        "AWS",
        "AI-Augmented Development",
        "OpenCode",
        "Claude"
      ],
      "hasCredential": [
        "BSc (Hons) Web Programming",
        "GradEx 2015 Winner (Web Category)"
      ]
    })} />
  </head>
  <body class="bg-tokyo-bg text-tokyo-fg font-mono min-h-screen">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-tokyo-accent focus:text-tokyo-bg focus:rounded">Skip to main content</a>
    <slot />
  </body>
</html>
