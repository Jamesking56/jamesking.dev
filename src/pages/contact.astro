---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact" description="Get in touch with James King for AI consulting, technical leadership, DevOps work, or web development services. Based in Redditch, UK.">
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold text-tokyo-fg-bright mb-4">Get In Touch</h1>
    <p class="text-tokyo-muted mb-8">
      Have a project in mind? Let's talk.
    </p>
    
    <div class="grid md:grid-cols-2 gap-8">
      <!-- Contact Form -->
      <div class="bg-tokyo-bg-alt border border-tokyo-border rounded-lg p-6">
        <form 
          name="contact" 
          method="POST" 
          data-netlify="true" 
          netlify-honeypot="bot-field"
          class="space-y-4"
          id="contact-form"
        >
          <input name="bot-field" type="text" class="hidden" tabindex="-1" autocomplete="off" />
          
          <div>
            <label for="name" class="block text-sm text-tokyo-fg mb-2">Name</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              autocomplete="name"
              class="w-full px-3 py-2 bg-tokyo-bg border border-tokyo-border rounded text-tokyo-fg focus:border-tokyo-accent focus:ring-2 focus:ring-tokyo-accent/30 focus:outline-none"
            />
          </div>
          
          <div>
            <label for="email" class="block text-sm text-tokyo-fg mb-2">Email</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              autocomplete="email"
              class="w-full px-3 py-2 bg-tokyo-bg border border-tokyo-border rounded text-tokyo-fg focus:border-tokyo-accent focus:ring-2 focus:ring-tokyo-accent/30 focus:outline-none"
            />
          </div>
          
          <div>
            <label for="message" class="block text-sm text-tokyo-fg mb-2">Message</label>
            <textarea 
              id="message" 
              name="message" 
              rows="5" 
              required
              autocomplete="off"
              class="w-full px-3 py-2 bg-tokyo-bg border border-tokyo-border rounded text-tokyo-fg focus:border-tokyo-accent focus:ring-2 focus:ring-tokyo-accent/30 focus:outline-none"
            ></textarea>
          </div>
          
          <button 
            type="submit" 
            class="w-full px-4 py-2 bg-tokyo-accent text-tokyo-bg font-semibold rounded hover:bg-tokyo-accent-hover transition-colors"
          >
            Send Message
          </button>
        </form>
        
        <!-- Success message (hidden by default) -->
        <div id="success-message" class="hidden mt-4 p-4 bg-tokyo-success/20 border border-tokyo-success rounded text-tokyo-fg">
          <p class="font-semibold text-tokyo-success">Message sent!</p>
          <p class="text-sm mt-1">Thanks for reaching out. I'll get back to you soon.</p>
        </div>
      </div>
      
      <!-- Contact Info -->
      <div class="space-y-4">
        <div class="bg-tokyo-bg-alt border border-tokyo-border rounded-lg p-6">
          <h2 class="text-lg font-semibold text-tokyo-fg-bright mb-4">Other Ways to Connect</h2>
          
          <div class="space-y-4">
            <a href="mailto:james@jamesking.dev" class="flex items-center gap-3 text-tokyo-fg hover:text-tokyo-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-tokyo-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              james@jamesking.dev
            </a>
            
            <a href="https://linkedin.com/in/jamesking56" target="_blank" rel="noopener external" class="flex items-center gap-3 text-tokyo-fg hover:text-tokyo-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-tokyo-muted" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            
            <a href="https://github.com/Jamesking56" target="_blank" rel="noopener external" class="flex items-center gap-3 text-tokyo-fg hover:text-tokyo-accent transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-tokyo-muted" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
              GitHub
            </a>
          </div>
        </div>
        
        <div class="bg-tokyo-bg-alt border border-tokyo-border rounded-lg p-6">
          <h2 class="text-lg font-semibold text-tokyo-fg-bright mb-2">Location</h2>
          <p class="text-tokyo-fg">Redditch, UK</p>
        </div>
      </div>
    </div>
  </div>

  <script>
    const handleSubmit = event => {
      event.preventDefault();

      const myForm = event.target;
      const formData = new FormData(myForm);

      fetch("/", {
        method: "POST",
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(formData).toString()
      })
        .then(() => {
          myForm.classList.add('hidden');
          document.getElementById('success-message').classList.remove('hidden');
        })
        .catch(error => alert(error));
    };

    document.getElementById('contact-form').addEventListener('submit', handleSubmit);
  </script>
</Layout>